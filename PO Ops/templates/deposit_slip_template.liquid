<style>
  @page { size: A4; margin: 0.5cm; }
  * { margin: 0; padding: 0; box-sizing: border-box; }
  @media print { body { padding: 5px !important; margin: 0; } a { display: none !important; } }
  body { font-family: Arial, sans-serif; font-size: 8px; line-height: 1.15; padding: 10px; }
  .container { max-width: 800px; margin: 0 auto; border: 2px solid #000; }
  .header-text { text-align: right; padding: 2px 6px; font-size: 7px; font-style: italic; border-bottom: 1px solid #000; }
  .title-header { text-align: center; padding: 6px 10px; border-bottom: 2px solid #000; }
  .logo { max-width: 140px; height: auto; margin-bottom: 4px; }
  .banner { padding: 8px 10px; font-size: 8px; text-align: center; font-weight: bold; border-bottom: 2px solid #000; }
  .banner-paid { background-color: #d4edda; }
  table { width: 100%; border-collapse: collapse; }
  .items-table th { background: #f0f0f0; padding: 3px 2px; border: 1px solid #000; font-size: 7px; text-align: left; }
  .items-table td { padding: 3px 2px; border: 1px solid #000; font-size: 7px; vertical-align: top; }
  .text-right { text-align: right; }
  .text-center { text-align: center; }
  .cell-label { display: block; font-weight: bold; margin-bottom: 1px; font-size: 7px; }
  .totals-row td { font-size: 7px; padding: 2px 3px; border: 1px solid #000; }
  .total-row td { font-weight: bold; font-size: 8px; border: 1px solid #000; }
  .amount-row td { font-weight: bold; font-size: 8px; border: 1px solid #000; color: #000; }
  .disclaimer { border-top: 2px solid #000; padding: 5px 10px; font-size: 6.5px; color: #444; text-align: center; line-height: 1.5; }
</style>

{% comment %}
  Reads deposit status and amounts from Shopify order tags.
  Tags written by SIAS middleware on Pine payment completion:
    deposit:partial, paid:RsX, pending:RsX
    deposit:fully-paid, paid:RsX
{% endcomment %}

{% assign amount_paid = "" %}
{% assign amount_pending = "" %}
{% assign deposit_status = "" %}
{% for tag in order.tags %}
  {% assign t = tag | strip | downcase %}
  {% if t contains "paid:rs" %}{% assign amount_paid = t | remove: "paid:rs" %}{% endif %}
  {% if t contains "pending:rs" %}{% assign amount_pending = t | remove: "pending:rs" %}{% endif %}
  {% if t == "deposit:partial" %}{% assign deposit_status = "partial" %}{% endif %}
  {% if t == "deposit:fully-paid" %}{% assign deposit_status = "paid" %}{% endif %}
{% endfor %}

{% assign po_comments = "" %}
{% for na in order.note_attributes %}
  {% if na.name == "po_comments" %}{% assign po_comments = na.value %}{% endif %}
{% endfor %}

<div class="container">

  <div class="header-text">Deposit Receipt / Advance Confirmation Copy</div>

  <div class="title-header">
    <img src="https://cdn.shopify.com/s/files/1/0775/8322/0993/files/Timanti_Logo_Black.jpg?v=1766506323" alt="Timanti" class="logo"><br>
    <strong style="font-size: 13px;">Deposit Receipt</strong>
  </div>

  <table style="border-bottom: 2px solid #000;">
    <tr>
      <td style="width: 58%; padding: 4px 6px; border-right: 2px solid #000; font-size: 7px; line-height: 1.25; vertical-align: top;">
        <strong style="font-size: 8px;">AURACARAT PRIVATE LIMITED</strong><br>
        <strong>Office:</strong> C207 Crystal Plaza, New Link Road, Andheri (W), Mumbai – 400053<br>
        <strong>Store:</strong> 17th Cross, 19th Main Rd, HSR Layout Sec 2, Opp. Gnan Srishti School, Bengaluru – 560102<br>
        <strong>Tel:</strong> +91-7710938305 | <strong>Email:</strong> hello@timanti.in<br>
        <strong>GSTIN</strong> – 29ABBCA3309B1Z7 | <strong>PAN</strong> – ABBCA3309B<br>
        <strong>Website:</strong> www.timanti.in
      </td>
      <td style="width: 42%; vertical-align: top; padding: 0;">
        <table>
          <tr>
            <td style="padding: 3px 5px; border-bottom: 1px solid #000; border-right: 1px solid #000; font-size: 7px; width: 33%;"><span class="cell-label">Receipt No.</span>{{ order.order_number }}</td>
            <td style="padding: 3px 5px; border-bottom: 1px solid #000; border-right: 1px solid #000; font-size: 7px; width: 33%;"><span class="cell-label">Draft Order</span>{{ order.name }}</td>
            <td style="padding: 3px 5px; border-bottom: 1px solid #000; font-size: 7px; width: 34%;"><span class="cell-label">Date</span>{{ order.created_at | date: "%d-%m-%Y" }}</td>
          </tr>
          <tr>
            <td style="padding: 3px 5px; border-right: 1px solid #000; font-size: 7px;"><span class="cell-label">Order Total</span>Rs.{{ order.total_price | money_without_currency | remove: ',' }}</td>
            <td style="padding: 3px 5px; border-right: 1px solid #000; font-size: 7px;"><span class="cell-label">Amount Paid</span><strong>{% if amount_paid != "" %}Rs.{{ amount_paid }}{% else %}–{% endif %}</strong></td>
            <td style="padding: 3px 5px; font-size: 7px;"><span class="cell-label">Balance Due</span>{% if deposit_status == "partial" %}<strong>Rs.{{ amount_pending }}</strong>{% elsif deposit_status == "paid" %}Nil{% else %}–{% endif %}</td>
          </tr>
        </table>
      </td>
    </tr>
  </table>

  <table style="border-bottom: 2px solid #000;">
    <tr>
      <td style="width: 100%; padding: 4px 6px; font-size: 7px; line-height: 1.3; vertical-align: top;">
        <strong style="display: block; margin-bottom: 3px;">Customer / Billing Details:</strong>
        {% if order.billing_address %}
          <strong>Name:</strong> {{ order.billing_address.name | upcase }}<br>
          <strong>Address:</strong> {{ order.billing_address.address1 }}{% if order.billing_address.address2 %}, {{ order.billing_address.address2 }}{% endif %}, {{ order.billing_address.city }}, {{ order.billing_address.province }}<br>
          <strong>Mobile:</strong> {{ order.billing_address.phone | default: "–" }}<br>
          <strong>Email:</strong> {{ order.email }}
        {% endif %}
      </td>
    </tr>
  </table>

  {% if po_comments != "" %}
  <table style="border-bottom: 2px solid #000;">
    <tr>
      <td style="padding: 4px 6px; font-size: 7px; line-height: 1.3; background: #fffbe6;">
        <strong>Order Notes / Special Instructions:</strong> {{ po_comments }}
      </td>
    </tr>
  </table>
  {% endif %}

  <table class="items-table">
    <thead>
      <tr>
        <th class="text-center" style="width: 5%;">S.No.</th>
        <th style="width: 53%;">Item Description</th>
        <th class="text-center" style="width: 8%;">HSN</th>
        <th class="text-center" style="width: 7%;">Qty</th>
        <th class="text-right" style="width: 13%;">Unit Price</th>
        <th class="text-right" style="width: 14%;">Amount</th>
      </tr>
    </thead>
    <tbody>
      {% for line_item in order.line_items %}
      <tr>
        <td class="text-center">{{ forloop.index }}.</td>
        <td>
          <strong>{{ line_item.title }}</strong>
          {% if line_item.variant.title != 'Default Title' %}<br><span style="color: #666; font-size: 6.5px;">{{ line_item.variant.title }}</span>{% endif %}
          {% if line_item.sku %}<br><span style="color: #999; font-size: 6.5px;">SKU: {{ line_item.sku }}</span>{% endif %}
          {% for property in line_item.properties %}{% assign pfc = property.first | slice: 0 %}{% if property.last != blank and pfc != '_' %}<br><span style="color: #555; font-size: 6.5px;">{{ property.first }}: {{ property.last }}</span>{% endif %}{% endfor %}
        </td>
        <td class="text-center">
          {% if line_item.product.metafields.custom.hsn_code %}{{ line_item.product.metafields.custom.hsn_code }}{% else %}71131914{% endif %}
        </td>
        <td class="text-center">{{ line_item.quantity }}</td>
        <td class="text-right">Rs.{{ line_item.price | money_without_currency | remove: ',' }}</td>
        <td class="text-right">Rs.{{ line_item.final_line_price | money_without_currency | remove: ',' }}</td>
      </tr>
      {% endfor %}

      <tr class="totals-row">
        <td colspan="5" class="text-right"><strong>Order Total (incl. GST @ 3%)</strong></td>
        <td class="text-right"><strong>Rs.{{ order.total_price | money_without_currency | remove: ',' }}</strong></td>
      </tr>
      {% if amount_paid != "" %}
      <tr class="amount-row">
        <td colspan="5" class="text-right">Amount Received</td>
        <td class="text-right">Rs.{{ amount_paid }}</td>
      </tr>
      {% endif %}
      {% if deposit_status == "partial" and amount_pending != "" %}
      <tr class="amount-row">
        <td colspan="5" class="text-right">Balance Pending (due before dispatch)</td>
        <td class="text-right">Rs.{{ amount_pending }}</td>
      </tr>
      {% elsif deposit_status == "paid" %}
      <tr class="amount-row">
        <td colspan="5" class="text-right">Balance Due</td>
        <td class="text-right">Nil</td>
      </tr>
      {% endif %}
    </tbody>
  </table>

  <table style="border-top: 2px solid #000;">
    <tr>
      <td style="width: 50%; padding: 4px 6px; border-right: 2px solid #000; font-size: 6.5px; line-height: 1.3; vertical-align: top;">
        <strong style="font-size: 7px; display: block; margin-bottom: 2px;">Terms</strong>
        <p style="margin-bottom: 1px;"><strong>1.</strong> This is a deposit receipt only. It is NOT a GST tax invoice. The final GST tax invoice will be issued at dispatch with actual jewellery specifications and jewellery code.</p>
        <p style="margin-bottom: 1px;"><strong>2.</strong> All jewellery is BIS Hallmarked. Certificate details will appear on the final tax invoice.</p>
        <p><strong>3.</strong> Refer company website for full terms including return and exchange policy.</p>
      </td>
      <td style="width: 50%; padding: 4px 6px; font-size: 6.5px; line-height: 1.3; vertical-align: top;">
        <strong style="font-size: 7px; display: block; margin-bottom: 2px;">Bank Details</strong>
        <p style="margin-bottom: 1px;"><strong>ACCOUNT NAME:</strong> AURACARAT PVT LTD</p>
        <p style="margin-bottom: 1px;"><strong>BANK ACC NO:</strong> 924020062754092</p>
        <p style="margin-bottom: 1px;"><strong>IFSC:</strong> UTIB0000186</p>
        <p style="margin-bottom: 1px;"><strong>BANK:</strong> AXIS BANK, MATRU SMRITI, LINKING ROAD, KHAR WEST, MUMBAI 400052</p>
        <p style="text-align: right; margin-top: 6px;"><strong>For – Auracarat Private Limited</strong></p>
      </td>
    </tr>
  </table>

  <div class="disclaimer">
    <strong>COMPUTER GENERATED DOCUMENT</strong> — This deposit receipt is electronically generated and legally valid without a physical signature or stamp per the Information Technology Act, 2000. This is NOT a GST tax invoice. The final tax invoice will be issued at dispatch.
  </div>

</div>
